{%- style -%}
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid var(--color-border);
  }
  .product-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .product-card__image-wrapper {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-contrast);
    overflow: hidden;
  }
  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-card__info {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .product-card__title {
    font-size: 1rem;
    margin: 0 0 var(--space-2) 0;
    color: var(--color-text-dark);
  }
  .product-card__price {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: var(--space-4);
  }
  .product-card__form {
    margin-top: auto;
  }
  .btn--full {
    width: 100%;
  }
{%- endstyle -%}

<div class="product-card">
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title | escape }}">
    <div class="product-card__image-wrapper">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy" class="product-card__image">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-card__image' }}
      {%- endif -%}
    </div>
    <div class="product-card__info">
      <h3 class="product-card__title">{{ product.title | default: 'Тестова іграшка' }}</h3>
      <div class="product-card__price">{{ product.price | default: 150000 | money }}</div>
    </div>
  </a>
  <div class="product-card__form" style="padding: 0 var(--space-4) var(--space-4);">
    <form action="/cart/add" method="post">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="btn btn--full" {% unless product.available or product == blank %}disabled{% endunless %}>
        {%- if product.available or product == blank -%}У кошик{%- else -%}Немає в наявності{%- endif -%}
      </button>
    </form>
  </div>
</div>