{% liquid
  assign section_style = '--section-top:' | append: section.settings.padding_top | append: 'px;--section-bottom:' | append: section.settings.padding_bottom | append: 'px;'
%}

<section class="section-shell section-shell--compact trust-strip" style="{{ section_style }}">
  <div class="section-shell__inner">
    <div class="trust-strip__shell surface-card">
      {% if section.settings.heading != blank or section.settings.text != blank %}
        <div class="trust-strip__intro">
          {% if section.settings.eyebrow != blank %}
            <p class="section-heading__eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2>{{ section.settings.heading }}</h2>
          {% endif %}

          {% if section.settings.text != blank %}
            <p class="section-heading__text">{{ section.settings.text }}</p>
          {% endif %}
        </div>
      {% endif %}

      <div class="trust-strip__grid">
        {% for block in section.blocks %}
          <article class="trust-strip__item" {{ block.shopify_attributes }}>
            <span class="icon-circle">
              {% render 'icon-ui', icon: block.settings.icon %}
            </span>
            <div class="trust-strip__item-copy">
              <strong>{{ block.settings.heading }}</strong>
              {% if block.settings.text != blank %}
                <p>{{ block.settings.text }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust strip",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Що важливо перед покупкою"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Тут усе працює на спокійне замовлення."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Реальні строки, природні матеріали, ручна робота і сервіс без неясностей."
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Point",
      "limit": 5,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "handmade", "label": "Handmade" },
            { "value": "shield", "label": "Safety" },
            { "value": "gift", "label": "Gift" },
            { "value": "star", "label": "Trust / highlight" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Реальні строки"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Одразу кажемо, коли чекати замовлення."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
