{%- style -%}
  .trust-strip {
    background-color: var(--color-surface);
    padding: var(--space-6) var(--space-4);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .trust-strip__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-6);
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .trust-item__title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-dark);
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .trust-item__text {
    font-size: 0.875rem;
    color: var(--color-text);
    margin: 0;
  }
{%- endstyle -%}

<section class="trust-strip">
  <div class="trust-strip__grid">
    {%- for block in section.blocks -%}
      <div class="trust-item" {{ block.shopify_attributes }}>
        <div class="trust-item__title">{{ block.settings.title | escape }}</div>
        <p class="trust-item__text">{{ block.settings.text | escape }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust Strip",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "trust_point",
      "name": "Trust Point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Доставка"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Дбайлива доставка у ваш дім."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Strip",
      "blocks": [
        { "type": "trust_point", "settings": { "title": "Доставка", "text": "Дбайлива доставка у ваш дім." } },
        { "type": "trust_point", "settings": { "title": "Матеріали", "text": "Чисте дерево. Природні барвники." } },
        { "type": "trust_point", "settings": { "title": "Ручна робота", "text": "Кожна деталь виточена майстрами." } },
        { "type": "trust_point", "settings": { "title": "Пакування", "text": "Готово до свята. Жодних турбот." } },
        { "type": "trust_point", "settings": { "title": "Гарантія", "text": "Працюємо офіційно. Безпечна покупка." } }
      ]
    }
  ]
}
{% endschema %}