{% liquid
  capture trust_title
    render 'localized-value', source: section.settings, key: 'title'
  endcapture
%}

{%- style -%}
  .trust-strip {
    padding-block: clamp(3rem, 7vw, 5rem) clamp(4rem, 8vw, 6rem);
  }

  .trust-strip__panel {
    display: grid;
    gap: 1.4rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(71, 53, 36, 0.12);
  }

  .trust-strip__intro {
    display: grid;
    gap: 0.5rem;
  }

  .trust-strip__title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.02;
    max-width: 12ch;
  }

  .trust-strip__list {
    display: grid;
    gap: 0;
  }

  .trust-strip__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    padding-block: 1rem;
    border-top: 1px solid rgba(71, 53, 36, 0.12);
  }

  .trust-strip__item:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .trust-strip__item-index {
    color: var(--color-accent-deep);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .trust-strip__item-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 0.2rem;
    letter-spacing: -0.01em;
  }

  .trust-strip__item-text {
    font-size: 0.94rem;
    line-height: 1.65;
  }

  @media (min-width: 990px) {
    .trust-strip__panel {
      grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
      gap: clamp(1.5rem, 4vw, 3rem);
      align-items: start;
    }

    .trust-strip__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 1.5rem;
    }

    .trust-strip__item {
      min-height: 100%;
      align-content: start;
    }

    .trust-strip__item:nth-child(2) {
      border-top: 0;
      padding-top: 0;
    }
  }
{%- endstyle -%}

<section class="trust-strip">
  <div class="page-width">
    <div class="trust-strip__panel">
      {% if trust_title != blank %}
        <div class="trust-strip__intro animate-fade-up">
          <span class="section-kicker">{{ 'theme.brand_promises' | t }}</span>
          <h2 class="trust-strip__title">{{ trust_title | strip }}</h2>
        </div>
      {% endif %}

      <div class="trust-strip__list">
        {%- for block in section.blocks -%}
          {% capture trust_block_title %}
            {% render 'localized-value', source: block.settings, key: 'title' %}
          {% endcapture %}
          {% capture trust_block_text %}
            {% render 'localized-value', source: block.settings, key: 'text' %}
          {% endcapture %}
          <article class="trust-strip__item" {{ block.shopify_attributes }}>
            <span class="trust-strip__item-index">0{{ forloop.index }}</span>
            <div>
              <div class="trust-strip__item-title">{{ trust_block_title | strip | escape }}</div>
              <p class="trust-strip__item-text">{{ trust_block_text | strip | escape }}</p>
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Strip",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Чому цей магазин відчувається надійно"
    },
    {
      "type": "text",
      "id": "title_en",
      "label": "Title EN",
      "default": "Why this shop feels considered and reliable"
    }
  ],
  "max_blocks": 5,
  "blocks": [
    {
      "type": "trust_point",
      "name": "Trust Point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Доставка"
        },
        {
          "type": "text",
          "id": "title_en",
          "label": "Heading EN",
          "default": "Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Дбайлива доставка у ваш дім."
        },
        {
          "type": "text",
          "id": "text_en",
          "label": "Text EN",
          "default": "Careful delivery to your door."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Strip",
      "blocks": [
        { "type": "trust_point", "settings": { "title": "Доставка", "text": "Дбайлива доставка у ваш дім." } },
        { "type": "trust_point", "settings": { "title": "Матеріали", "text": "Чисте дерево. Природні барвники." } },
        { "type": "trust_point", "settings": { "title": "Ручна робота", "text": "Кожна деталь виточена майстрами." } },
        { "type": "trust_point", "settings": { "title": "Пакування", "text": "Готово до свята. Жодних турбот." } },
        { "type": "trust_point", "settings": { "title": "Гарантія", "text": "Працюємо офіційно. Безпечна покупка." } }
      ]
    }
  ]
}
{% endschema %}
