{% liquid
  capture section_eyebrow
    render 'localized-value', source: section.settings, key: 'eyebrow'
  endcapture
  capture section_title
    render 'localized-value', source: section.settings, key: 'title'
  endcapture
  capture section_text
    render 'localized-value', source: section.settings, key: 'text'
  endcapture
  capture section_note
    render 'localized-value', source: section.settings, key: 'note'
  endcapture
  capture section_button_label
    render 'localized-value', source: section.settings, key: 'button_label'
  endcapture

  assign about_image_alt = section_title | strip
  if section.settings.image != blank and section.settings.image.alt != blank
    assign about_image_alt = section.settings.image.alt
  endif
%}

{%- style -%}
  .about-story {
    padding-block: clamp(4rem, 8vw, 6.5rem);
  }

  .about-story__layout {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }

  .about-story__content {
    display: grid;
    gap: var(--space-5);
  }

  .about-story__title {
    font-size: clamp(2.5rem, 6vw, 4.8rem);
    max-width: 10ch;
  }

  .about-story__text {
    max-width: 40rem;
    font-size: clamp(1rem, 1.8vw, 1.12rem);
    line-height: 1.85;
  }

  .about-story__note {
    max-width: 34rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(71, 53, 36, 0.12);
    line-height: 1.8;
  }

  .about-story__media {
    min-height: 22rem;
    border-radius: clamp(1rem, 2.6vw, 1.5rem);
    overflow: hidden;
    background: linear-gradient(135deg, rgba(220, 192, 161, 0.35), rgba(156, 103, 64, 0.08));
  }

  .about-story__image,
  .about-story__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-story__placeholder {
    color: rgba(32, 24, 18, 0.26);
  }

  .about-story__facts {
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
    display: grid;
    gap: 0;
  }

  .about-story__fact {
    padding-block: 1rem;
    border-top: 1px solid rgba(71, 53, 36, 0.12);
  }

  .about-story__fact-title {
    margin-bottom: 0.35rem;
    color: var(--color-text-dark);
    font-size: 0.98rem;
    font-family: var(--font-body);
    font-weight: 700;
  }

  .about-story__fact-text {
    line-height: 1.7;
  }

  @media (min-width: 990px) {
    .about-story__layout {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    }

    .about-story__media {
      min-height: 36rem;
    }

    .about-story__facts {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      column-gap: 1.5rem;
    }
  }
{%- endstyle -%}

<section class="about-story">
  <div class="page-width">
    <div class="about-story__layout">
      <div class="about-story__content">
        {% if section_eyebrow != blank %}
          <span class="section-kicker">{{ section_eyebrow | strip }}</span>
        {% endif %}

        <h1 class="about-story__title">{{ section_title | strip }}</h1>

        {% if section_text != blank %}
          <div class="about-story__text rte">{{ section_text | strip }}</div>
        {% endif %}

        {% if section_note != blank %}
          <p class="about-story__note">{{ section_note | strip }}</p>
        {% endif %}

        {% if section_button_label != blank and section.settings.button_link != blank %}
          <div>
            <a href="{{ section.settings.button_link }}" class="text-link">{{ section_button_label | strip }}</a>
          </div>
        {% endif %}
      </div>

      <div class="about-story__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1800
            | image_tag:
              class: 'about-story__image',
              loading: 'lazy',
              widths: '640, 900, 1200, 1500, 1800',
              sizes: '(min-width: 990px) 52vw, 100vw',
              alt: about_image_alt
          }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'about-story__placeholder' }}
        {% endif %}
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      <div class="about-story__facts">
        {%- for block in section.blocks -%}
          {% capture fact_title %}
            {% render 'localized-value', source: block.settings, key: 'title' %}
          {% endcapture %}
          {% capture fact_text %}
            {% render 'localized-value', source: block.settings, key: 'text' %}
          {% endcapture %}
          <div class="about-story__fact" {{ block.shopify_attributes }}>
            <div class="about-story__fact-title">{{ fact_title | strip }}</div>
            <p class="about-story__fact-text">{{ fact_text | strip }}</p>
          </div>
        {%- endfor -%}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "About Story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Vlasnoruch atelier"
    },
    {
      "type": "text",
      "id": "eyebrow_en",
      "label": "Eyebrow EN",
      "default": "Vlasnoruch atelier"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Майстерня, де дерево відчувається теплим з першого дотику."
    },
    {
      "type": "text",
      "id": "title_en",
      "label": "Title EN",
      "default": "An atelier where wood feels warm from the first touch."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Ми працюємо з ясеном і дубом так, щоб кожна іграшка лишалася спокійною на вигляд, чесною в матеріалі та приємною в руці. Без зайвого декору, зате з увагою до пропорцій, ваги і щоденного користування.</p>"
    },
    {
      "type": "richtext",
      "id": "text_en",
      "label": "Text EN",
      "default": "<p>We work with ash and oak so each toy feels calm in appearance, honest in material, and beautiful in the hand. No visual excess, just attention to proportion, weight, and everyday use.</p>"
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Note",
      "default": "Для нас важливо, щоб річ однаково добре жила в дитячій кімнаті, на подарунок і в пам'яті родини через роки."
    },
    {
      "type": "textarea",
      "id": "note_en",
      "label": "Note EN",
      "default": "We want each piece to live just as naturally in a child's room, as a gift, and later as part of family memory."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Переглянути колекцію"
    },
    {
      "type": "text",
      "id": "button_label_en",
      "label": "Button label EN",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Fact",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Матеріал"
        },
        {
          "type": "text",
          "id": "title_en",
          "label": "Title EN",
          "default": "Material"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Працюємо з ясеном і дубом, які добре старіють і красиво показують текстуру."
        },
        {
          "type": "textarea",
          "id": "text_en",
          "label": "Text EN",
          "default": "We work with ash and oak that age well and reveal their grain beautifully."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Story",
      "blocks": [
        { "type": "fact" },
        { "type": "fact" },
        { "type": "fact" }
      ]
    }
  ]
}
{% endschema %}
