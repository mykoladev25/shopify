{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<h1>{{ 'cart.title' | t }}</h1>

<form action="{{ routes.cart_url }}" method="post" class="cart__form">
  <div class="cart__layout">
    
    <div class="cart__items">
      <table>
        {% for item in cart.items %}
          <tr>
            <td class="cart__item-image">
              {% render 'image', image: item.image, url: item.url %}
            </td>
            <td class="cart__item-details">
              <p class="cart__item-title">{{ item.product.title }}</p>
              {{ 'cart.remove' | t | link_to: item.url_to_remove, class: 'cart__item-remove' }}
            </td>
            <td class="cart__item-quantity">
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              <button type="submit" class="cart__update-btn button secondary">{{ 'cart.update' | t }}</button>
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>

    <div class="cart__summary">
      <h2 class="cart__summary-title">{{ 'cart.summary_title' | t }}</h2>
      
      <div class="cart__subtotal">
        <span>{{ 'cart.subtotal' | t }}</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      
      <p class="cart__taxes-note">{{ 'cart.taxes_note' | t }}</p>

      <button type="submit" name="checkout" class="button cart__checkout-btn">
        {{ 'cart.checkout' | t }}
      </button>
    </div>

  </div>
</form>

<style>
  {{ 'cart.css' | inline_asset_content }}
</style>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
