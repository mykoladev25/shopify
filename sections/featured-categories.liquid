{% liquid
  assign section_style = '--section-top:' | append: section.settings.padding_top | append: 'px;--section-bottom:' | append: section.settings.padding_bottom | append: 'px;'
%}

<section class="section-shell featured-categories" style="{{ section_style }}">
  <div class="section-shell__inner">
    <div class="featured-categories__header section-heading--split">
      <div class="section-heading">
        {% if section.settings.eyebrow != blank %}
          <p class="section-heading__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <p class="section-heading__text">{{ section.settings.text }}</p>
        {% endif %}
      </div>

      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <div class="featured-categories__header-action">
          <a href="{{ section.settings.cta_link }}" class="button button--secondary">
            {{ section.settings.cta_label }}
          </a>
        </div>
      {% endif %}
    </div>

    <div class="featured-categories__grid">
      {% for block in section.blocks %}
        {% liquid
          assign target_collection = block.settings.collection
          assign card_title = block.settings.heading | default: target_collection.title
          assign card_text = block.settings.text
          if card_text == blank and target_collection.description != blank
            assign card_text = target_collection.description | strip_html | truncate: 90
          endif

          assign card_link = block.settings.custom_link | default: target_collection.url
          assign card_image = block.settings.image | default: target_collection.featured_image | default: target_collection.image
        %}

        <article class="featured-categories__card" {{ block.shopify_attributes }}>
          <a href="{{ card_link | default: routes.all_products_collection_url }}" class="featured-categories__card-link">
            <div class="featured-categories__media">
              {% if card_image != blank %}
                {{ card_image | image_url: width: 900 | image_tag: widths: '320,480,640,900', sizes: '(min-width: 990px) 25vw, 50vw', loading: 'lazy', alt: card_title }}
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag }}
              {% endif %}
            </div>

            <div class="featured-categories__body">
              {% if block.settings.badge != blank %}
                {% render 'badge', label: block.settings.badge %}
              {% endif %}

              {% if card_title != blank %}
                <h3>{{ card_title }}</h3>
              {% endif %}

              {% if card_text != blank %}
                <p>{{ card_text }}</p>
              {% endif %}

              {% if block.settings.button_label != blank %}
                <span class="featured-categories__cta">
                  {{ block.settings.button_label }}
                  {% render 'icon-ui', icon: 'arrow' %}
                </span>
              {% endif %}
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured categories",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Почніть з потрібного"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Оберіть категорію під свій запит."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Подарунок, перша дерев'яна іграшка, улюблений транспорт або весь каталог."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Усі колекції"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 12,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 24,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "limit": 4,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "custom_link",
          "label": "Custom link"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Переглянути"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured categories",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
