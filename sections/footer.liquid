<footer class="site-footer">
  <div class="section-shell__inner site-footer__grid">
    <div class="site-footer__intro">
      <h3>{{ section.settings.heading }}</h3>
      <p>{{ section.settings.text }}</p>
      {% if section.settings.contact_email != blank %}
        <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
      {% endif %}
    </div>

    <div class="site-footer__links">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </div>

    <div class="site-footer__intro">
      <p class="site-footer__meta">{{ section.settings.shipping_note }}</p>
      {% if section.settings.show_payment_icons %}
        <div class="site-footer__payments">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        </div>
      {% endif %}
      <p class="site-footer__meta">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Купувати тут спокійно."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Ми прямо говоримо про вироби, строки і сервіс. Саме так будується довіра до покупки."
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email"
    },
    {
      "type": "text",
      "id": "shipping_note",
      "label": "Shipping/payment note",
      "default": "Подарункова подача, відстеження посилки і зрозуміла комунікація на кожному етапі."
    }
  ]
}
{% endschema %}
