{% liquid
  assign section_label = section.settings.section_label
  assign section_title = section.settings.title
%}

{{ 'best-sellers.css' | asset_url | stylesheet_tag }}
<script src="{{ 'best-sellers.js' | asset_url }}" defer></script>

{% if section.blocks.size > 0 %}
  <section class="best-sellers" data-section-type="best-sellers" data-section-id="{{ section.id }}">
    <div class="best-sellers__container">
      <div class="best-sellers__left">
        {% if section_label != blank %}
          <p class="best-sellers__subtitle">{{ section_label }}</p>
        {% endif %}

        {% if section_title != blank %}
          <h2 class="best-sellers__title">{{ section_title }}</h2>
        {% endif %}

        <ul class="best-sellers__tabs" role="tablist">
          {% for block in section.blocks %}
            {% liquid
              assign collection = block.settings.collection
              assign custom_title = block.settings.collection_title
              if custom_title != blank
                assign tab_title = custom_title
              elsif collection != blank
                assign tab_title = collection.title
              else
                assign tab_title = 'Collection ' | append: forloop.index
              endif
            %}
            <li class="best-sellers__tab" role="presentation">
              <button
                class="best-sellers__tab-btn{% if forloop.first %} is-active{% endif %}"
                role="tab"
                type="button"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="bs-panel-{{ section.id }}-{{ block.id }}"
                data-bs-tab-index="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                <span>{{ tab_title }}</span>
                {{ 'arrow-right.svg' | inline_asset_content }}
              </button>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="best-sellers__right">
        {% for block in section.blocks %}
          {% liquid
            assign collection = block.settings.collection
            assign custom_product = block.settings.product
            if custom_product != blank
              assign product = custom_product
            elsif collection != blank and collection.products.size > 0
              assign product = collection.products.first
            else
              assign product = nil
            endif

            assign is_sold_out = false
            if product != blank and product.available == false
              assign is_sold_out = true
            endif

            assign first_available_variant = nil
            if product != blank
              for variant in product.variants
                if variant.available and first_available_variant == nil
                  assign first_available_variant = variant
                endif
              endfor
              if first_available_variant == nil
                assign first_available_variant = product.selected_or_first_available_variant
              endif
            endif
          %}

          <div
            class="best-sellers__product{% if forloop.first %} is-active{% endif %}"
            id="bs-panel-{{ section.id }}-{{ block.id }}"
            role="tabpanel"
            data-bs-product-index="{{ forloop.index0 }}"
            data-bs-product-name="{{ product.title | escape }}"
            data-bs-variant-id="{{ first_available_variant.id }}"
            data-bs-sold-out="{{ is_sold_out }}"
          >
            <div class="best-sellers__product-image-wrap">
              {% if product != blank and product.featured_image != blank %}
                <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                  <picture>
                    <source
                      media="(max-width: 768px)"
                      srcset="
                        {{ product.featured_image | image_url: width: 480 }} 1x,
                        {{ product.featured_image | image_url: width: 960 }} 2x
                      "
                    >
                    <source
                      media="(min-width: 769px)"
                      srcset="
                        {{ product.featured_image | image_url: width: 700 }} 1x,
                        {{ product.featured_image | image_url: width: 1400 }} 2x
                      "
                    >
                    <img
                      src="{{ product.featured_image | image_url: width: 700 }}"
                      alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
                      loading="lazy"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                    >
                  </picture>
                </a>
              {% elsif product != blank %}
                <a href="{{ product.url }}" aria-label="{{ product.title | escape }}">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </a>
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
              {% if product != blank and product.tags.size > 0 %}
                <div class="best-sellers__tags">
                  {% assign tag_count = 0 %}
                  {% for tag in product.tags %}
                    {% if tag_count < 3 %}
                      <span class="best-sellers__tag{% if tag == 'Sale' %} best-sellers__tag--sale{% endif %}">
                        {{ tag }}
                      </span>
                      {% assign tag_count = tag_count | plus: 1 %}
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}

              <div class="best-sellers__actions">
                <button
                  class="best-sellers__action-btn best-sellers__action-btn--cart"
                  type="button"
                  aria-label="Add to cart"
                  data-bs-add-to-cart
                  {% if is_sold_out %}disabled{% endif %}
                >
                  {{ 'eye.svg' | inline_asset_content }}
                </button>
                <button
                  class="best-sellers__action-btn best-sellers__action-btn--wishlist"
                  type="button"
                  aria-label="Add to wishlist"
                  data-bs-wishlist
                >
                  <span class="best-sellers__icon--mobile" aria-hidden="true">
                    {{ 'wishlist.svg' | inline_asset_content }}
                  </span>
                  <span class="best-sellers__icon--desktop" aria-hidden="true">
                    {{ 'heart.svg' | inline_asset_content }}
                  </span>
                </button>
              </div>

              {% if product != blank %}
                <div class="best-sellers__product-info">
                  <a href="{{ product.url }}" class="best-sellers__product-name">
                    {{ product.title }}
                  </a>
                  <div class="best-sellers__product-price">
                    {% if product.compare_at_price > product.price %}
                      <span class="best-sellers__price--current">{{ product.price | money }}</span>
                      <span class="best-sellers__price--compare">{{ product.compare_at_price | money }}</span>
                    {% else %}
                      <span class="best-sellers__price--regular">{{ product.price | money }}</span>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="best-sellers__overlay" data-bs-overlay></div>
    <div class="best-sellers__modal" data-bs-modal role="dialog" aria-modal="true">
      <button class="best-sellers__modal-close" type="button" data-bs-modal-close aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <p class="best-sellers__modal-text" data-bs-modal-text></p>
    </div>
  </section>

{% else %}
  <section class="best-sellers" data-section-type="best-sellers" data-section-id="{{ section.id }}">
    <div class="best-sellers__container">
      <div class="best-sellers__left">
        {% if section_label != blank %}
          <p class="best-sellers__subtitle">{{ section_label }}</p>
        {% endif %}
        {% if section_title != blank %}
          <h2 class="best-sellers__title">{{ section_title }}</h2>
        {% endif %}
        <p style="color: var(--bs-color-text-muted); font-size: 14px; padding: 16px 0;">
          Add collection blocks in the theme editor to display products.
        </p>
      </div>
      <div class="best-sellers__right" style="background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 300px;">
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Best sellers",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section label",
      "default": "Best sellers"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Trending Products"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 3,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "Collection title",
          "info": "Overrides the default collection title if set."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Overrides the first product of the collection if set."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best sellers",
      "blocks": []
    }
  ]
}
{% endschema %}
