{%- style -%}
  .product-main {
    padding: var(--space-8) var(--space-4);
    background: var(--color-bg);
  }
  .product-main__wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 1200px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .product-main__wrapper {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }
  .product-gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .product-gallery__main {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-contrast);
    border: 1px solid var(--color-border);
  }
  .product-gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .product-info__title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0;
    line-height: 1.1;
  }
  .product-info__price {
    font-size: 1.5rem;
    font-weight: 500;
  }
  .product-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }
  .product-form__quantity {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .product-form__quantity input {
    width: 60px;
    padding: var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-align: center;
    background: var(--color-surface);
    color: var(--color-text-dark);
  }
  .product-info__description {
    color: var(--color-text);
    line-height: 1.6;
  }
{%- endstyle -%}

<section class="product-main">
  <div class="product-main__wrapper">
    <div class="product-gallery">
      <div class="product-gallery__main">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 1000 }}" alt="{{ product.title | escape }}" loading="eager">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>
    </div>
    
    <div class="product-info">
      <h1 class="product-info__title">{{ product.title | default: 'Еко-іграшка з дерева' }}</h1>
      <div class="product-info__price">{{ product.price | default: 250000 | money }}</div>
      
      <div class="product-info__description">
        {{ product.description | default: '<p>Чудова дерев’яна іграшка, створена з любов’ю та турботою про вашу дитину. Екологічні матеріали, безпечні фарби.</p>' }}
      </div>
      
      <form action="/cart/add" method="post" class="product-form" id="product-form-{{ section.id }}">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        <div class="product-form__quantity">
          <label for="Quantity-{{ section.id }}">Кількість</label>
          <input type="number" id="Quantity-{{ section.id }}" name="quantity" value="1" min="1" form="product-form-{{ section.id }}">
        </div>
        
        <button type="submit" class="btn btn--full" {% unless product.available or product == blank %}disabled{% endunless %}>
          {%- if product.available or product == blank -%}
            Додати в кошик
          {%- else -%}
            Немає в наявності
          {%- endif -%}
        </button>
      </form>
      
      <div class="trust-mini" style="margin-top: var(--space-4); font-size: 0.875rem; color: var(--color-text);">
        <p>✓ Екологічні матеріали, сертифіковані для найменших.</p>
        <p>✓ Працюємо офіційно. Безпечна покупка.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Product",
  "tag": "section",
  "settings": []
}
{% endschema %}