{% liquid
  assign featured_collection = collections[section.settings.collection]
  if featured_collection == blank
    assign featured_collection = collections['all']
  endif

  capture section_eyebrow
    render 'localized-value', source: section.settings, key: 'eyebrow'
  endcapture
  capture section_title
    render 'localized-value', source: section.settings, key: 'title'
  endcapture
  capture section_text
    render 'localized-value', source: section.settings, key: 'text'
  endcapture
  capture section_button_label
    render 'localized-value', source: section.settings, key: 'button_label'
  endcapture
%}

{%- style -%}
  .featured-products__intro {
    display: grid;
    gap: 0.8rem;
    margin-bottom: clamp(1.2rem, 3vw, 1.8rem);
  }

  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.95rem 0.85rem;
  }

  .featured-products__footer {
    margin-top: clamp(1.35rem, 4vw, 2rem);
    display: flex;
    justify-content: flex-start;
  }

  @media (min-width: 768px) {
    .featured-products__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }

  @media (min-width: 1200px) {
    .featured-products__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: clamp(1.25rem, 2.5vw, 1.6rem);
    }
  }
{%- endstyle -%}

<section class="featured-products section-shell">
  <div class="page-width">
    <div class="featured-products__intro">
      <div class="animate-fade-up">
        {% if section_eyebrow != blank %}
          <span class="section-kicker">{{ section_eyebrow | strip }}</span>
        {% endif %}
        <h2 class="section-title" style="margin-top: 0.45rem;">{{ section_title | strip | escape }}</h2>
      </div>

      {% if section_text != blank %}
        <p class="section-copy animate-fade-up delay-1">{{ section_text | strip }}</p>
      {% endif %}
    </div>

    <div class="featured-products__grid">
      {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          {% render 'product-card', product: blank %}
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {% if section_button_label != blank %}
      <div class="featured-products__footer">
        <a href="{{ section.settings.button_link | default: featured_collection.url | default: routes.all_products_collection_url }}" class="text-link">
          {{ section_button_label | strip }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Вибране"
    },
    {
      "type": "text",
      "id": "eyebrow_en",
      "label": "Eyebrow EN",
      "default": "From the atelier"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Обране для ваших малюків"
    },
    {
      "type": "text",
      "id": "title_en",
      "label": "Heading EN",
      "default": "A thoughtful place to begin"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Ключові моделі, з яких зручно почати знайомство з брендом: продумана форма, тепла палітра дерева і готовність до щоденної гри."
    },
    {
      "type": "textarea",
      "id": "text_en",
      "label": "Text EN",
      "default": "If you are meeting Vlasnoruch atelier for the first time, start with the pieces that best show the shape, weight, and tactile warmth of the wood."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Дивитися весь каталог"
    },
    {
      "type": "text",
      "id": "button_label_en",
      "label": "Button label EN",
      "default": "Browse the full collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
