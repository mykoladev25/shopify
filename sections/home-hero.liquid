{% liquid
  assign section_style = '--section-top:' | append: section.settings.padding_top | append: 'px;--section-bottom:' | append: section.settings.padding_bottom | append: 'px;'
  assign hero_classes = 'section-shell home-hero'
  if section.settings.mobile_media_first
    assign hero_classes = hero_classes | append: ' home-hero--media-first'
  endif
%}

<section class="{{ hero_classes }}" style="{{ section_style }}">
  <div class="section-shell__inner">
    <div class="home-hero__frame">
      <div class="home-hero__content">
        <div class="home-hero__copy">
          {% if section.settings.badge_text != blank %}
            {% render 'badge', label: section.settings.badge_text, tone: 'accent' %}
          {% endif %}

          {% if section.settings.eyebrow != blank %}
            <p class="eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h1>{{ section.settings.heading }}</h1>
          {% endif %}

          {% if section.settings.text != blank %}
            <div class="rte">{{ section.settings.text }}</div>
          {% endif %}
        </div>

        <div class="home-hero__actions">
          {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
            <a href="{{ section.settings.primary_link }}" class="button">
              {{ section.settings.primary_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
            <a href="{{ section.settings.secondary_link }}" class="button button--secondary">
              {{ section.settings.secondary_label }}
            </a>
          {% endif %}
        </div>

        {% if section.blocks.size > 0 %}
          <div class="home-hero__benefits" aria-label="Hero trust signals">
            {% for block in section.blocks %}
              <article class="home-hero__benefit" {{ block.shopify_attributes }}>
                <span class="icon-circle">
                  {% render 'icon-ui', icon: block.settings.icon %}
                </span>
                <div>
                  <strong>{{ block.settings.heading }}</strong>
                  {% if block.settings.text != blank %}
                    <p>{{ block.settings.text }}</p>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="home-hero__media-wrap">
        <div class="home-hero__media">
          <picture>
            {% if section.settings.image_mobile != blank %}
              <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 900 }}">
            {% endif %}

            {% if section.settings.image != blank %}
              {{ section.settings.image | image_url: width: 1800 | image_tag: widths: '540,720,960,1200,1600,1800', sizes: '(min-width: 990px) 48vw, 100vw', loading: 'eager', fetchpriority: 'high', alt: section.settings.image.alt | default: section.settings.heading }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag }}
            {% endif %}
          </picture>
        </div>

        {% if section.settings.support_heading != blank or section.settings.support_text != blank %}
          <div class="home-hero__support surface-card">
            {% if section.settings.support_label != blank %}
              <p class="home-hero__support-label">{{ section.settings.support_label }}</p>
            {% endif %}

            {% if section.settings.support_heading != blank %}
              <h3 class="home-hero__support-heading">{{ section.settings.support_heading }}</h3>
            {% endif %}

            {% if section.settings.support_text != blank %}
              <p>{{ section.settings.support_text }}</p>
            {% endif %}

            {% if section.settings.support_link_label != blank and section.settings.support_link != blank %}
              <a href="{{ section.settings.support_link }}" class="button button--ghost">
                {{ section.settings.support_link_label }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home hero",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Зроблено руками"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Дерев'яні іграшки для спокійної гри, добрих подарунків і теплих дитячих спогадів"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Іграшки, які приємно дарувати і хочеться зберігати."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Природна фактура, уважна ручна робота, подарункова подача і доставка по Україні та за кордон.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Переглянути каталог"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Ідеї для подарунка"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "checkbox",
      "id": "mobile_media_first",
      "label": "Show image before copy on mobile",
      "default": false,
      "info": "Improves visual impact on small screens when photography carries the story."
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Support card label",
      "default": "Подарункова подача"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support card heading",
      "default": "Можна дарувати одразу"
    },
    {
      "type": "textarea",
      "id": "support_text",
      "label": "Support card text",
      "default": "Оформлення підсилює враження від речі ще до моменту вручення."
    },
    {
      "type": "text",
      "id": "support_link_label",
      "label": "Support card link label",
      "default": "Дивитися підбірку"
    },
    {
      "type": "url",
      "id": "support_link",
      "label": "Support card link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 24,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Trust signal",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "handmade", "label": "Handmade" },
            { "value": "shield", "label": "Shield" },
            { "value": "gift", "label": "Gift" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "star", "label": "Star" }
          ],
          "default": "handmade"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Зроблено руками"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "У кожній деталі є увага"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home hero",
      "blocks": [
        { "type": "highlight" },
        { "type": "highlight" },
        { "type": "highlight" },
        { "type": "highlight" }
      ]
    }
  ]
}
{% endschema %}
