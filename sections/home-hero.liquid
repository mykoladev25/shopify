{%- style -%}
  .hero-{{ section.id }} {
    padding: clamp(var(--space-12), 15vw, var(--space-24)) var(--space-4);
    background-color: var(--color-bg);
    min-height: 90vh;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .hero-{{ section.id }} {
      grid-template-columns: 50% 50%;
      padding: 0 var(--space-16);
    }
  }
  .hero-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    padding-right: var(--space-8);
  }
  .hero-{{ section.id }}__eyebrow {
    font-family: var(--font-body);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }
  .hero-{{ section.id }}__title {
    font-size: clamp(3.5rem, 8vw, 7rem);
    color: var(--color-text-dark);
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
    line-height: 0.95;
  }
  .hero-{{ section.id }}__title span {
    font-style: italic;
    color: var(--color-accent);
  }
  .hero-{{ section.id }}__text {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: var(--color-text);
    margin-bottom: var(--space-8);
    max-width: 480px;
    line-height: 1.6;
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-6);
  }
  .hero-{{ section.id }}__cta {
    display: flex;
    gap: var(--space-4);
  }
  .hero-{{ section.id }}__image-wrapper {
    height: 50vh;
    width: 100%;
    margin-top: var(--space-8);
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-float);
    order: -1; /* Move image above text on mobile */
    margin-bottom: var(--space-6);
  }
  .hero-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    padding-right: 0;
  }
  @media (min-width: 1024px) {
    .hero-{{ section.id }} {
      grid-template-columns: 50% 50%;
      padding: 0 var(--space-16);
    }
    .hero-{{ section.id }}__image-wrapper {
      order: 0;
      margin-top: 0;
      margin-bottom: 0;
      height: 110%;
      width: 120%;
      position: absolute;
      right: -10%;
      top: -5%;
      border-radius: var(--radius-xl) 0 0 var(--radius-xl);
      transform: rotate(-2deg);
      transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hero-{{ section.id }}__content {
      padding-right: var(--space-8);
    }
    .hero-{{ section.id }}:hover .hero-{{ section.id }}__image-wrapper {
      transform: rotate(0deg) scale(1.02);
    }
  }
  .hero-{{ section.id }}__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-{{ section.id }}__badge {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-4);
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    padding: var(--space-2) var(--space-4);
    border-radius: 100px;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-text-dark);
    box-shadow: var(--shadow-md);
    z-index: 3;
  }
  @media (min-width: 1024px) {
    .hero-{{ section.id }}__badge { 
      bottom: var(--space-8);
      left: -20px;
      padding: var(--space-4) var(--space-6);
      font-size: 1.25rem;
    }
  }
{%- endstyle -%}

<section class="hero-{{ section.id }}">
  <div class="hero-{{ section.id }}__image-wrapper animate-scale delay-2">
    <div class="hero-{{ section.id }}__badge animate-fade-up delay-4">Ручна робота. Ясен та дуб.</div>
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 1400 }}" alt="Hero Image" class="hero-{{ section.id }}__image" loading="eager">
    {%- else -%}
      <img src="https://images.unsplash.com/photo-1596461404969-9ae70f2830c1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" alt="Wooden toy" class="hero-{{ section.id }}__image" loading="eager">
    {%- endif -%}
  </div>
  
  <div class="hero-{{ section.id }}__content">
    <div class="hero-{{ section.id }}__eyebrow animate-fade-up">Екологічні іграшки</div>
    <h1 class="hero-{{ section.id }}__title animate-fade-up delay-1">
      Тепло,<br>яке можна <span>відчути.</span>
    </h1>
    <div class="hero-{{ section.id }}__text animate-fade-up delay-2">{{ section.settings.text }}</div>
    <div class="hero-{{ section.id }}__cta animate-fade-up delay-3">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Створено руками. Передається у спадок."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Ми віримо, що іграшка має залишати слід у пам'яті, а не на планеті. Кожна деталь виточується вручну з масиву ясена та дуба, покривається лляною олією та бджолиним воском.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Переглянути колекцію"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}