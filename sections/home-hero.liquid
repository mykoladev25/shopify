{%- style -%}
  .hero-{{ section.id }} {
    padding: var(--space-16) var(--space-4);
    text-align: center;
    background-color: var(--color-bg);
  }
  .hero-{{ section.id }}__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--color-text-dark);
    margin-bottom: var(--space-4);
    max-width: 800px;
    margin-inline: auto;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .hero-{{ section.id }}__text {
    font-size: 1.125rem;
    color: var(--color-text);
    margin-bottom: var(--space-8);
    max-width: 600px;
    margin-inline: auto;
  }
{%- endstyle -%}

<section class="hero-{{ section.id }}">
  <div class="page-width">
    <h1 class="hero-{{ section.id }}__title">{{ section.settings.title | escape }}</h1>
    <div class="hero-{{ section.id }}__text">{{ section.settings.text }}</div>
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Home Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Створено руками. Передається у спадок."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Чисте дерево. Природні барвники. Безкомпромісна якість.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Переглянути колекцію"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}