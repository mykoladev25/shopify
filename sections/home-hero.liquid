{%- style -%}
  .hero-{{ section.id }} {
    padding: clamp(var(--space-12), 15vw, var(--space-24)) var(--space-4);
    background-color: var(--color-bg);
    min-height: 85vh;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .hero-{{ section.id }} {
      grid-template-columns: 55% 45%;
      padding: 0 var(--space-16);
    }
  }
  .hero-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    padding-right: var(--space-8);
  }
  .hero-{{ section.id }}__title {
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    color: var(--color-text-dark);
    margin-bottom: var(--space-6);
    letter-spacing: -0.04em;
    line-height: 1;
    font-style: italic;
  }
  .hero-{{ section.id }}__text {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    color: var(--color-text);
    margin-bottom: var(--space-8);
    max-width: 480px;
    line-height: 1.6;
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-4);
    font-family: var(--font-body);
  }
  .hero-{{ section.id }}__cta {
    display: flex;
    gap: var(--space-4);
  }
  .hero-{{ section.id }}__image-wrapper {
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-{{ section.id }}__image-wrapper {
      display: block;
      height: 120%;
      width: 100%;
      position: absolute;
      right: -5%;
      top: -10%;
      background: var(--color-surface);
      border-radius: 40% 0 0 40%;
      transform: rotate(-3deg);
      box-shadow: inset 0 0 100px rgba(0,0,0,0.02);
      z-index: 0;
    }
  }
{%- endstyle -%}

<section class="hero-{{ section.id }}">
  <div class="hero-{{ section.id }}__image-wrapper"></div>
  <div class="hero-{{ section.id }}__content">
    <h1 class="hero-{{ section.id }}__title">{{ section.settings.title | escape }}</h1>
    <div class="hero-{{ section.id }}__text">{{ section.settings.text }}</div>
    <div class="hero-{{ section.id }}__cta">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Створено руками. Передається у спадок."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Чисте дерево. Природні барвники. Безкомпромісна якість.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Переглянути колекцію"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Home Hero"
    }
  ]
}
{% endschema %}