{% liquid
  assign current_language_iso = localization.language.iso_code | default: request.locale.iso_code
  assign locale_prefix = current_language_iso | slice: 0, 2
  assign featured_collection_title = section.settings.title

  if featured_collection_title == blank or locale_prefix == 'uk'
    assign featured_collection_title = 'featured_collection.title' | t
  endif
%}

{{ 'featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

{{ 'featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}

<section class="featured-collection">
  {% if featured_collection_title != blank %}
    <h2 class="featured-collection__title">{{ featured_collection_title }}</h2>
  {% endif %}

  <div class="featured-collection__slider-wrapper">
    <ul class="featured-collection__list" role="list">
      {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
        <li class="featured-collection__item">
          {% render 'product-card', product: product %}
        </li>
      {% else %}
        {% for i in (1..4) %}
          <li class="featured-collection__item">
            <div class="product-card">
              <div class="product-card__image-wrapper">
                {% capture current %}{% cycle 1, 2, 3, 4 %}{% endcapture %}
                {{ 'product-' | append: current | placeholder_svg_tag: 'product-card__image' }}
              </div>
              <div class="product-card__info">
                <h3 class="product-card__title">{{ 'featured_collection.placeholder_title' | t }}</h3>
                <span class="product-card__price">{{ 150000 | money }}</span>
              </div>
            </div>
          </li>
        {% endfor %}
      {% endfor %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "t:general.featured_collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.heading",
      "default": "Bestsellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "t:labels.max_products"
    }
  ],
  "presets": [
    {
      "name": "t:general.featured_collection"
    }
  ]
}
{% endschema %}
