{% liquid
  assign current_language_iso = localization.language.iso_code | default: request.locale.iso_code
  assign locale_prefix = current_language_iso | slice: 0, 2
  assign announcement_text = section.settings.announcement_text

  if announcement_text == blank or locale_prefix == 'uk'
    assign announcement_text = 'header.announcement' | t
  endif
%}

{%- if section.settings.show_announcement and announcement_text != blank -%}
  <p class="announcement">
    <span class="announcement__content">
      {{ announcement_text }}
    </span>
  </p>
{%- endif -%}
<header>
  <div class="header-content">
    <a href="{{ routes.root_url }}" class="header__logo-link header__title">
    {%- if settings.logo != blank -%}
      {%- assign logo_width = settings.logo_width -%}
      {{ settings.logo | image_url: width: logo_width | image_tag: class: 'header__logo-img', loading: 'eager' }}
    {%- else -%}
    <h2 class="header__title">
      {{ shop.name | link_to: routes.root_url }}
    </h2>
    {%- endif -%}
    </a>

    <nav class="header__menu desktop-only">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </nav>

    <button id="menu-open" class="burger-btn mobile-only" aria-label="{{ 'header.open_menu' | t }}"></button>

    <dialog id="mobile-menu" class="mobile-drawer">
      <nav class="mobile-drawer__nav">
        <ul>
          {% for link in section.settings.menu.links %}
            {{ link.title | link_to: link.url }}
          {% endfor %}
        </ul>
      </nav>
      <button id="menu-close" class="close-btn" aria-label="{{ 'header.close_menu' | t }}">
        {{ 'header.close_menu' | t }}
      </button>
    </dialog>

    <div class="header__icons">
      {% if localization.available_languages.size > 1 %}
        {% form 'localization', class: 'header__locale-form' %}
          <div class="header__locale-switcher" role="group" aria-label="{{ 'header.language' | t }}">
            {% for language in localization.available_languages %}
              {% liquid
                assign language_label = language.iso_code | upcase

                if language.iso_code == 'uk'
                  assign language_label = 'UA'
                endif
              %}

              <button
                type="submit"
                name="language_code"
                value="{{ language.iso_code }}"
                class="header__locale-button{% if language.iso_code == current_language_iso %} is-active{% endif %}"
                aria-label="{{ language.endonym_name | default: language.name }}"
              >
                {{ language_label }}
              </button>
            {% endfor %}
          </div>
        {% endform %}
      {% endif %}

      {% if shop.customer_accounts_enabled %}
        <a href="{{ settings.account_url }}" aria-label="{{ 'customers.login.title' | t }}">{% render 'icon-account' %}</a>
      {% endif %}

      <a href="{{ routes.cart_url }}" aria-label="{{ 'cart.title' | t }}">
        {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
        {% endif %}

        {% render 'icon-cart' %}
      </a>
    </div>
  </div>
</header>
<script src="{{ 'header.js' | asset_url }}" defer></script>
<style>
  {{ 'header-layout.css' | inline_asset_content }}
  {{ 'burger-menu.css' | inline_asset_content }}
</style>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "t:labels.show_announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "t:labels.announcement_text",
      "default": "Welcome to the Vlasnoruch toy store!"
    }
  ]
}
{% endschema %}
