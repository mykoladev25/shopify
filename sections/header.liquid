<header class="site-header">
  <div class="site-header__inner">
    <a href="{{ routes.root_url }}" class="site-header__logo">
      {{ shop.name }}
    </a>
    <nav class="site-header__nav">
      {%- for link in linklists.main-menu.links -%}
        <a href="{{ link.url }}" class="site-header__link">{{ link.title }}</a>
      {%- endfor -%}
    </nav>
    <div class="site-header__actions">
      <button type="button" class="site-header__cart-btn" aria-label="Відкрити кошик" onclick="document.querySelector('cart-drawer').open()">
        Кошик (<span class="cart-count">{{ cart.item_count }}</span>)
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-4);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .site-header__logo {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text-dark);
    text-decoration: none;
  }
  .site-header__nav {
    display: none;
  }
  @media (min-width: 768px) {
    .site-header__nav {
      display: flex;
      gap: var(--space-6);
    }
  }
  .site-header__link {
    color: var(--color-text-dark);
    text-decoration: none;
    font-weight: 500;
  }
  .site-header__cart-btn {
    background: none;
    border: none;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-dark);
    cursor: pointer;
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}