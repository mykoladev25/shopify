<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#D8CEC2">
    <title>Незабаром відкриття | {{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      .password-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background-color: var(--color-bg);
        text-align: center;
        padding: var(--space-4);
      }
      .password-box {
        background: var(--color-surface);
        padding: var(--space-8);
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-border);
        max-width: 500px;
        width: 100%;
        box-shadow: var(--shadow-md);
      }
      .password-input {
        width: 100%;
        padding: 12px;
        margin-bottom: var(--space-4);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
      }
    </style>
  </head>
  <body>
    <div class="password-page">
      <div class="password-box">
        <h1 style="margin-bottom: var(--space-4);">{{ shop.name }}</h1>
        <p style="margin-bottom: var(--space-6); color: var(--color-text);">Створено руками. Передається у спадок.<br><br>Магазин на стадії розробки. Введіть пароль для доступу.</p>
        
        {% form 'storefront_password' %}
          {{ form.errors | default_errors }}
          <input type="password" name="password" class="password-input" placeholder="Пароль магазину" autofocus>
          <button type="submit" class="btn btn--full">Увійти</button>
        {% endform %}
        <div style="display: none;">{{ content_for_layout }}</div>
      </div>
    </div>
  </body>
</html>